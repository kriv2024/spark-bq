*.swo
*~
# VS Code — ignore personal/local files
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.vscode/*.code-snippets

# OS specific
.DS_Store
Thumbs.db

# Data files (be careful with this - you might want to track some sample data)
data/raw/
data/processed/
!data/sample/
data

# Google Cloud credentials
service-account-*.json
credentials.json
key.json

# Auto-generated by setuptools_scm
src/_version.py

# Generated notebook resources (SVGs produced during study sessions)
notebooks/resources/

# pip install artifact files (created when running: pip install pkg==version)
=*

# Claude Code local overrides (personal, not team-wide)
.claude/settings.local.json
